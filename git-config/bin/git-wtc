#!/usr/bin/env bash
_hug_category='["worktrees"]'
_hug_keywords='["create-worktree", "new-worktree", "linked-checkout"]'
test "${1:-}" = '--search-meta' && {
  printf 'category = %s\nkeywords = %s\n' "$_hug_category" "$_hug_keywords"
  exit 0
}
# Assume HUG_HOME is set (exported by hug or environment)
# shellcheck source=git-config/lib/hug-common
. "$HUG_HOME/git-config/lib/hug-common"
# shellcheck source=git-config/lib/hug-git-kit
. "$HUG_HOME/git-config/lib/hug-git-kit"
# shellcheck source=git-config/lib/hug-git-worktree
. "$HUG_HOME/git-config/lib/hug-git-worktree"
set -euo pipefail # Exit on error, undefined vars, pipe failures
# Part of the Hug tool suite

show_help() {
  cat << 'EOF'
hug wtc: Create worktree for existing or new branch

USAGE:
    hug wtc [options]
    hug wtc <branch> [path] [options]
    hug wtc -h|--help

ARGUMENTS:
    [branch]        Name of branch to create worktree for. Can be existing or new branch. If omitted or `--`, interactive branch selection menu is displayed.
    [path]          Custom path for worktree (optional, auto-generated if not provided).

OPTIONS:
    -f, --force             Skip confirmation prompts, auto-create branches, and allow
                            creating worktrees for branches checked out elsewhere
    -y, --yes               Skip confirmation prompts. NOT sufficient for operations requiring -f.
    --dry-run               Show what would be done without creating the worktree
    --new, -B, --with-branch  Automatically create branch if it doesn't exist
    --base POINT            Create the new branch from POINT (commit, branch, tag, or ref)
                            instead of HEAD. Implies --new. Errors if branch already exists.
    -p, --path PATH         Explicit worktree path (alternative to positional arg)
    -q, --quiet             Suppress summary and informational output (errors and JSON remain)
    --json                  Emit results as JSON on stdout (zero non-JSON bytes; pipe-safe)
    -h, --help              Show this help

DESCRIPTION:
    Creates a new Git worktree for the specified branch. Worktrees allow you to
    work on multiple branches simultaneously without context switching overhead.

    If no path is provided, generates a smart default path as a sibling of
    the current working tree: ../<repo>.WT.<branch>. From a submodule, the
    default is a sibling of the submodule (e.g. ../<sub>.WT.<branch>) —
    placement is chosen so relative paths to sibling submodules remain valid.

    By default, the branch must exist locally. With --new flag or with --force,
    non-existent branches will be created automatically from the current HEAD.
    Use --base to create from a different start-point (branch, tag, commit, or ref).

    If the branch is currently checked out in the main worktree, --force is
    required to create a worktree for it.

    Interactive mode shows only branches that don't already have worktrees,
    preventing duplicate worktree creation errors.

EXAMPLES:
    hug wtc                                 # Interactive branch selection, auto-generated path
    hug wtc --                              # Interactive branch selection, auto-generated path
    hug wtc feature-auth                    # Create worktree for existing branch
    hug wtc feature-auth --new              # Create new branch and worktree
    hug wtc feature-auth -B                 # Same as --new (alias)
    hug wtc new-feature -B ~/work/feat      # Create new branch at custom path
    hug wtc new-feature -p ~/work/feat -B   # Same, using -p for path
    hug wtc missing-branch                  # Prompt to create branch if it doesn't exist
    hug wtc missing-branch -f               # Auto-create branch without prompting
    hug wtc feature-auth --dry-run          # Preview creation without doing it
    hug wtc feature-auth --dry-run -f       # Preview with force semantics (compose)
    hug wtc feature-auth -f                 # Create without confirmation
    hug wtc hotfix-123 --base v2.0          # Create branch from tag
    hug wtc experiment --base main           # Create branch from main
    hug wtc feature --base origin/develop    # Create branch from remote
    hug wtc test-ref --base HEAD~3 --dry-run -f  # Preview with force override
    hug wtc scripty --new --json -y         # Scriptable JSON output to stdout
    hug wtc quiet-branch --new -q -y        # Suppress summary chatter

SAFETY:
    -y answers yes to routine confirmations (safe and recoverable tiers).
    It never authorizes dangerous operations — those require -f/--force.
    -f also overrides blocked states (branch checked out in main worktree).

EXIT CODES:
    0  success            2  usage error (bad flags/arguments)
    1  operational error  3  blocked by safety (use -f where appropriate)

SEE ALSO:
    hug wt      List and switch between worktrees
    hug wtdel   Remove worktree safely

FURTHER READING:
    See 'git worktree add --help' for underlying implementation details.
EOF
}

check_git_repo

# Parse arguments using getopt
# NOTE: hug-common already sources hug-json, so json_escape / to_json_nested
# are available without an explicit source here.
set +e # Temporarily disable exit on error to capture getopt failure
PARSED=$(getopt --options hfyBqp: --longoptions help,force,dry-run,new,with-branch,base:,yes,quiet,json,path: --name "hug wtc" -- "$@" 2>&1)
getopt_status=$?
set -e # Re-enable exit on error

if [ $getopt_status -ne 0 ]; then
  # getopt failed - print the error message if available
  if [ -n "$PARSED" ]; then
    echo "$PARSED" >&2
  fi
  exit 2 # usage error — unknown flag or malformed value (exit-code §6)
fi

eval set -- "$PARSED"

# Initialize variables
force=false
dry_run=false
new_branch=false
base=""
json_output=false
flag_path=""

# Process options
while true; do
  case "$1" in
  -h | --help)
    show_help
    exit 0
    ;;
  -f | --force)
    force=true
    shift
    ;;
  -y | --yes)
    export HUG_YES=true
    shift
    ;;
  --dry-run)
    dry_run=true
    shift
    ;;
  --new)
    new_branch=true
    shift
    ;;
  -B | --with-branch) # -B is a memorable alias for --new
    new_branch=true
    shift
    ;;
  --base)
    base="$2"
    shift 2
    ;;
  -q | --quiet) # Suppress summary chatter (stdout stays clean)
    export HUG_QUIET=T
    shift
    ;;
  --json) # Machine-readable result object to stdout
    json_output=true
    shift
    ;;
  -p | --path) # Explicit worktree path (alternative to positional arg)
    if [[ -z "${2:-}" ]]; then
      error_usage "-p/--path requires a non-empty value."
    fi
    flag_path="$2"
    shift 2
    ;;
  --)
    shift
    break
    ;;
  *)
    error "Internal error in option parsing"
    ;;
  esac
done

# Honor HUG_FORCE environment variable (parity with wtdel; design §5).
# This lets scripts set HUG_FORCE=true instead of passing -f on every invocation.
if [[ ${HUG_FORCE:-} == true ]]; then
  force=true
fi

# --base implies --new (user's intent is clearly to create from a specific point)
if [[ -n "$base" ]]; then
  new_branch=true
fi

# Validate --base commitish exists and is resolvable (fail-fast before prompts)
if [[ -n "$base" ]]; then
  if ! git rev-parse --verify --quiet "$base^{commit}" > /dev/null 2>&1; then
    error "Cannot resolve --base '$base' to a commit. Branches, tags, hashes, and relative refs (HEAD~N) are all accepted — verify the ref exists (try: hug ll)."
  fi
fi

# Parse arguments
if [[ $# -eq 0 ]]; then
  # No arguments provided - show interactive branch selection
  branch_name=""
  worktree_path=""
elif [[ $# -eq 1 ]]; then
  if [[ "$1" == "--" ]]; then
    # Interactive branch selection
    branch_name=""
    worktree_path=""
  else
    # Branch name provided
    branch_name="$1"
    worktree_path=""
  fi
elif [[ $# -eq 2 ]]; then
  if [[ "$1" == "--" ]]; then
    # Interactive branch selection, custom path provided
    branch_name=""
    worktree_path="$2"
  else
    # Branch name and path both provided
    branch_name="$1"
    worktree_path="$2"
  fi
elif [[ $# -gt 2 ]]; then
  error_usage "Too many arguments. Usage: hug wtc [branch] [path]. See 'hug wtc --help'."
fi

# If -p/--path was given, merge it into worktree_path (error on conflict).
# This runs AFTER the $# case block so positional args are already captured.
if [[ -n "$flag_path" ]]; then
  if [[ -n "$worktree_path" ]]; then
    error_usage "Provide the worktree path either as a positional argument or via -p/--path, not both."
  fi
  worktree_path="$flag_path"
fi

# Interactive branch selection if needed
if [[ -z "$branch_name" ]]; then
  # Show interactive branch selection using existing branch menu functions
  selected_branch=""

  if ! eval "$(python3 "$HUG_HOME/git-config/lib/python/hug_git_branch.py" local)"; then
    error "No local branches found."
    exit 1
  fi

  # Filter out branches that already have worktrees
  declare -a available_branches=() available_hashes=() available_subjects=() available_tracks=()
  for ((i = 0; i < ${#branches[@]}; i++)); do
    branch="${branches[i]}"
    if branch_available_for_worktree "$branch"; then
      available_branches+=("$branch")
      available_hashes+=("${hashes[i]}")
      available_subjects+=("${subjects[i]}")
      available_tracks+=("${tracks[i]}")
    fi
  done

  if [[ ${#available_branches[@]} -eq 0 ]]; then
    error "All branches already have worktrees. Use 'hug wtl' to see existing worktrees."
    exit 1
  fi

  # Print interactive menu and get selection (display functions unchanged)
  declare -a available_dates=()
  if ! print_interactive_branch_menu selected_branch "$current_branch" "$max_len" available_hashes available_dates available_branches available_tracks available_subjects; then
    info "Worktree creation cancelled."
    exit 1
  fi

  branch_name="$selected_branch"
fi

# --- PRE-VALIDATION ---
branch_exists=false
branch_needs_creation=false
confirmed_via_branch_prompt=false

if git rev-parse --verify "refs/heads/$branch_name" > /dev/null 2>&1; then
  branch_exists=true
fi

# --base is incompatible with existing branches
if [[ -n "$base" ]] && $branch_exists; then
  error "Branch '$branch_name' already exists; --base only applies when creating new branches"
fi

if ! $branch_exists; then
  if $dry_run; then
    branch_needs_creation=true # Just note it for preview, no mutations
  elif $new_branch || $force; then
    branch_needs_creation=true # Will create without prompting
  else
    # Prompt once: branch doesn't exist, create it AND the worktree?
    echo >&2
    info "Branch '$branch_name' does not exist locally."
    if ! prompt_confirm_safe "Create branch '$branch_name' and its worktree?"; then
      exit 0
    fi
    branch_needs_creation=true
    confirmed_via_branch_prompt=true # Skip second confirmation
  fi
fi

# Validate branch availability (only for existing branches)
# exit-code §6: blocked by safety (exit 3)
if $branch_exists && ! branch_available_for_worktree "$branch_name"; then
  holding_wt=$(get_worktree_path_by_branch "$branch_name" || true)
  error_blocked "Branch '$branch_name' is checked out in worktree ${holding_wt:-<unknown>}. Remove it first (hug wtdel $branch_name) or pick another branch."
fi

# Check if branch is checked out in the main worktree (requires --force)
if $branch_exists && ! $force; then
  main_wt_path=$(resolve_main_worktree_path)
  main_wt_branch=$(git -C "$main_wt_path" rev-parse --abbrev-ref HEAD 2> /dev/null || echo "")
  if [[ "$branch_name" == "$main_wt_branch" ]]; then
    error_blocked "Branch '$branch_name' is currently checked out in the main worktree. Use -f/--force to create a worktree for it anyway."
  fi
fi

# Generate path if not provided
if [[ -z "$worktree_path" ]]; then
  worktree_path=$(generate_worktree_path "$branch_name")

  # Ensure path is unique (handle conflicts)
  if [[ -e "$worktree_path" ]]; then
    worktree_path=$(generate_unique_worktree_path "$branch_name")
    info "Default path exists, using: $worktree_path"
  fi
fi

# Convert relative path to absolute for validation
if [[ ! "$worktree_path" = /* ]]; then
  worktree_path="$(pwd)/$worktree_path"
fi

# Determine start-point label for display
if [[ -n "$base" ]]; then
  start_point_label="${YELLOW}(new, from $base)${NC}"
else
  start_point_label="${YELLOW}(new, from HEAD)${NC}"
fi

# --- DRY RUN ---
if $dry_run; then
  [[ -z "${HUG_QUIET:-}" ]] && {
    echo >&2
    printf "${BLUE}Worktree Creation Preview (DRY RUN):${NC}\n" >&2
    if $branch_needs_creation; then
      printf "  Branch: %s %s\n" "$branch_name" "$start_point_label" >&2
    else
      printf "  Branch: %s\n" "$branch_name" >&2
    fi
    printf "  Path:   %s\n" "${worktree_path/#$HOME/\~}" >&2
    echo >&2
  }
  info "No changes made (dry run)."
  exit 0
fi

# --- SUMMARY ---
[[ -z "${HUG_QUIET:-}" ]] && {
  echo >&2
  printf "${BLUE}Worktree Creation Summary:${NC}\n" >&2
  if $branch_needs_creation; then
    printf "  Branch: %s %s\n" "$branch_name" "$start_point_label" >&2
  else
    printf "  Branch: %s\n" "$branch_name" >&2
  fi
  printf "  Path:   %s\n" "${worktree_path/#$HOME/\~}" >&2
  echo >&2
}

# --- SINGLE CONFIRMATION ---
# Skip if forced, or if user already confirmed via branch-creation prompt
if ! $force && ! $confirmed_via_branch_prompt; then
  if ! prompt_confirm_safe "Create worktree?"; then
    exit 0
  fi
fi

# --- EXECUTE ---
# TODO: Extract create_branch_from_base() library function shared with git-bc's --point-to
# Create branch if needed
if $branch_needs_creation; then
  git_err=""
  if [[ -n "$base" ]]; then
    if ! git_err=$(git branch "$branch_name" "$base" 2>&1); then
      error "Failed to create branch '$branch_name' from '$base': $git_err"
    fi
    info "Created branch '$branch_name' from $base ($(git rev-parse --short "$base"))"
  else
    if ! git_err=$(git branch "$branch_name" 2>&1); then
      error "Failed to create branch '$branch_name': $git_err"
    fi
    info "Created branch '$branch_name' from $(git rev-parse --short HEAD)"
  fi
fi

# Validate creation path
if ! validate_worktree_creation_path "$worktree_path"; then
  # Rollback branch if we just created it
  if $branch_needs_creation; then
    git branch -d "$branch_name" 2> /dev/null || true
    warning "Rolled back branch '$branch_name' (worktree path invalid)."
  fi
  exit 1
fi

# Create worktree (capture stderr instead of suppressing it)
git_wt_args=("$worktree_path" "$branch_name")
if $force; then
  git_wt_args+=("--force")
fi
git_err=""
if ! git_err=$(git worktree add "${git_wt_args[@]}" 2>&1); then
  if $branch_needs_creation; then
    git branch -d "$branch_name" 2> /dev/null || true
    warning "Rolled back branch '$branch_name'."
  fi
  error "Failed to create worktree: $git_err"
fi

# Verify the worktree was actually created
if [[ ! -f "$worktree_path/.git" ]]; then
  error "Worktree creation appeared to succeed but the directory is invalid."
fi

# --- SUCCESS ---
success "Worktree created for '$branch_name'"
echo >&2
tip "To start working:  cd ${worktree_path/#$HOME/\~}"
suggest_superproject_ignore "$worktree_path"

# --- JSON OUTPUT (stdout) ---
# Emits a parseable result object when --json is requested.
# All human-facing chatter above went to stderr; this is the only stdout.
if $json_output; then
  _created=false
  _base_json=null
  _sp_json=null
  if $branch_needs_creation; then
    _created=true
    [[ -n "$base" ]] && _base_json="\"$(json_escape "$base")\""
    _sp_json="\"$(git rev-parse --short "refs/heads/$branch_name")\""
  fi
  to_json_nested \
    branch "\"$(json_escape "$branch_name")\"" \
    path "\"$(json_escape "$worktree_path")\"" \
    created_branch "$_created" \
    base "$_base_json" \
    start_point "$_sp_json"
  printf '\n'
fi
