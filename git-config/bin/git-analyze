#!/usr/bin/env bash
# git-analyze - Repository analysis gateway command
# Part of the Hug tool suite

CMD_BASE="$(readlink -f "$0" 2> /dev/null || greadlink -f "$0")" || CMD_BASE="$0"
CMD_BASE="$(dirname "$CMD_BASE")"

set -euo pipefail # Exit on error, undefined vars, pipe failures

dispatch_analyze_subcommand() {
  local subcommand="$1"
  shift
  local script_path="$CMD_BASE/git-analyze-$subcommand"

  # EDUCATIONAL NOTE:
  # Dispatch directly to the sibling script instead of re-entering Git via
  # `git analyze-<subcommand>`. Git treats `--help` specially and may show a
  # manpage lookup before the script's own `show_help()` can run. Direct exec
  # keeps gateway help behavior aligned with what users expect from Hug.
  if [[ -x "$script_path" ]]; then
    exec "$script_path" "$@"
  fi

  exec git "analyze-$subcommand" "$@"
}

show_help() {
  cat << 'EOF'
hug analyze: Repository analysis and insights

USAGE:
    hug analyze <command> [args]

COMMANDS:
    co-changes      Find files related to one target file or across the repo
    activity        Analyze temporal commit patterns and activity
    deps            Show dependency graph for commits/files
    expert          Identify code ownership and expertise areas

EXAMPLES:
    hug analyze co-changes src/auth/login.js   # Files related to a target file
    hug analyze activity --by-hour         # Activity by hour of day
    hug analyze deps abc1234               # Dependencies for commit
    hug analyze expert src/auth/login.js   # Who owns this file

For detailed help on each command:
    hug analyze <command> --help

SEE ALSO:
    hug stats        : Quick repository statistics
    hug lc           : Search code changes
    hug h files      : Files touched by commits
EOF
}

case "${1:-}" in
co-changes)
  shift
  dispatch_analyze_subcommand "co-changes" "$@"
  ;;
activity)
  shift
  dispatch_analyze_subcommand "activity" "$@"
  ;;
deps)
  shift
  dispatch_analyze_subcommand "deps" "$@"
  ;;
expert)
  shift
  dispatch_analyze_subcommand "expert" "$@"
  ;;
-h | --help | help) show_help ;;
*)
  if [ -n "${1:-}" ]; then
    printf 'Unknown analyze command: %s\n\n' "$1" >&2
  fi
  show_help
  exit 1
  ;;
esac
