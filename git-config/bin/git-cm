#!/usr/bin/env bash
# Retired command redirect: hug cm → hug cmod or hug c -m
#
# The short two-letter command `cm` was retired because agents and users
# frequently mistook it for "commit with message" (like `git commit -m`).
# The amend operation is now `hug cmod` (Commit MODify) — longer name for
# a dangerous operation, consistent with Hug's safety philosophy.

show_help() {
  cat << 'EOF'
hug cm has been retired.

  To commit WITH a message:   hug c -m "your message"
  To amend the last commit:   hug cmod
  To amend with all tracked:  hug cmoda

Run 'hug help cmod' for details on amending.
EOF
}

case "${1:-}" in
-h | --help)
  show_help
  exit 0
  ;;
esac

cat << 'EOF' >&2
error: hug cm has been retired.

  Did you mean to commit with a message?
    hug c -m "your message"

  Did you mean to amend the last commit?
    hug cmod        # staged changes only
    hug cmoda       # all tracked changes

Run 'hug help cmod' for details.
EOF
exit 1
