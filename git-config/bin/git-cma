#!/usr/bin/env bash
# Retired command redirect: hug cma → hug cmoda
#
# The short command `cma` was retired alongside `cm` for naming consistency.
# The amend-all operation is now `hug cmoda` (Commit MODify All).

show_help() {
  cat << 'EOF'
hug cma has been retired.

  To amend the last commit with all tracked changes:  hug cmoda
  To amend the last commit with staged changes only:  hug cmod
  To commit all tracked changes (new commit):         hug ca

Run 'hug help cmoda' for details on amending with all tracked changes.
EOF
}

case "${1:-}" in
-h | --help)
  show_help
  exit 0
  ;;
esac

cat << 'EOF' >&2
error: hug cma has been retired.

  Did you mean to amend the last commit with all tracked changes?
    hug cmoda       # amend with all tracked changes

  Other commit commands:
    hug cmod        # amend with staged changes only
    hug ca          # commit all tracked (new commit)

Run 'hug help cmoda' for details.
EOF
exit 1
