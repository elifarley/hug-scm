#!/usr/bin/env bash
_hug_category='["status"]'; test "${1:-}" = '--search-meta' && { printf 'category = %s\n' "$_hug_category"; exit 0; }
CMD_BASE="$(readlink -f "$0" 2> /dev/null || greadlink -f "$0")" || CMD_BASE="$0"
CMD_BASE="$(dirname "$CMD_BASE")"
for f in hug-common hug-git-kit; do . "$CMD_BASE/../lib/$f"; done
set -euo pipefail

# Part of the Hug tool suite

show_help() {
  cat << 'EOF'
hug sw: Show status with patch of working directory changes.

USAGE:
    hug sw [-s, --stat] [-q, --quiet] [-h, --help]
    hug sw [--] [<path>...]
    hug sw --
    hug sw --browse-root

ARGUMENTS:
    <path>...      Show working directory changes for specific paths (optional, supports multiple)
    --             With no paths: interactive file selection from changed files
                   With paths: separates flags from pathspecs

OPTIONS:
    --browse-root  Browse full repository scope in file selector UI (default: current directory)
    -s, --stat     Show only file statistics (omit patch)
    -q, --quiet    Suppress summary line (also honors HUG_QUIET env var)
    -h, --help     Show this help

DESCRIPTION:
    Shows the diff of all working directory changes, split into unstaged and
    staged sections. First shows unstaged diff with stats, then shows staged
    changes with stats, separated by a divider. By default shows both patch
    and statistics. Use '--stat' to show statistics only.

PATH FILTERING:
    Append -- <path>... to restrict output to matching paths.
    Globs must be quoted to prevent shell expansion.

    hug sw -- src/ tests/          # Show changes for two directories
    hug sw --stat -- '*.java'      # Stats for Java files only

EXAMPLES:
    hug sw                  # Show all working directory changes (unstaged + staged)
    hug sw --stat           # Show only statistics (no patches)
    hug sw file.txt         # Show working directory changes for specific file
    hug sw -- src/ tests/   # Show changes for two directories
    hug sw --               # Interactive file selection (current directory)
    hug sw --browse-root    # Interactive file selection (full repository)

SEE ALSO:
    hug ss       : Show staged diff
    hug su       : Show unstaged diff
    hug s        : Show status
EOF
}

# Delegate all argument processing and diff invocation to the shared driver
_diff_cmd_setup "combined" "--staged --unstaged" "Select file(s) to view uncommitted changes..." "$@"
