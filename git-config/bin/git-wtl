#!/usr/bin/env bash
CMD_BASE="$(readlink -f "$0" 2> /dev/null || greadlink -f "$0")" || CMD_BASE="$0"
CMD_BASE="$(dirname "$CMD_BASE")"
for f in hug-common hug-git-kit hug-git-worktree; do . "$CMD_BASE/../lib/$f"; done # Load common constants and functions
set -euo pipefail                                                                  # Exit on error, undefined vars, pipe failures

# Part of the Hug tool suite

show_help() {
  cat << 'EOF'
hug wtl: List worktrees in short format, showing path, branch, and status.

USAGE:
  hug wtl [OPTIONS] [SEARCH_TERM]

OPTIONS:
  -h, --help         Show this help message and exit.
  --json             Output in JSON format instead of human-readable text.
  -B, --branch BRANCH    Filter by exact branch name (repeatable, OR logic)

DESCRIPTION:
  Displays each worktree sorted alphabetically. The current worktree is highlighted in green and marked with an asterisk (*).
  Each entry shows: path [branch] [status indicators] (short commit).

  Indicators:
    *  current worktree
    +  dirty (uncommitted changes)
    #  locked
    @  detached HEAD
    .  (inactive)

  Filtering:
    - Search term: Case-insensitive substring match on path or branch name
    - -B / --branch: Exact branch name match (case-sensitive, repeatable)
    - Combined: Both filters must match (AND logic)

EXAMPLES:
  hug wtl                       # List all worktrees
  hug wtl feature               # List worktrees containing "feature" (path or branch)
  hug wtl --branch main         # List worktrees on branch "main" (exact match)
  hug wtl --branch f1 --branch f2  # List worktrees on "f1" OR "f2"
  hug wtl --branch main /home   # Branch is "main" AND path contains "/home"
  hug wtl --json                # Output worktree information in JSON format

SEE ALSO:
  hug wtll : For listing worktrees in long form
  hug wt   : For interactive worktree selection and switching
  hug wtdel : For removing worktrees safely
  hug wtwp : For listing worktrees by exact branch names
EOF
}

# Parse arguments
json_output=false
declare -a branch_filters=()
while [[ $# -gt 0 ]]; do
  case "$1" in
  --json)
    json_output=true
    shift
    ;;
  -B | --branch)
    if [[ -z "${2:-}" ]]; then
      error "--branch requires a value"
      exit 1
    fi
    branch_filters+=("$2")
    shift 2
    ;;
  -h | --help)
    show_help
    exit 0
    ;;
  *)
    # Treat remaining arguments as search terms
    break
    ;;
  esac
done

# Capture search terms (remaining positional args)
search_terms="$*"

# Convert branch_filters array to space-separated string for passing to functions
branch_filters_str="${branch_filters[*]:-}"

# Early exit if not in Git repo
check_git_repo

# JSON output mode
if $json_output; then
  # Get current worktree path for JSON
  current_worktree=$(get_current_worktree_path)
  output_worktree_json "$current_worktree" "$search_terms" "$branch_filters_str"
  exit 0
fi

# Get worktree data
# NOTE: wtl lists all worktrees, including the main repository
declare -a worktree_paths=() branches=() commits=() status_dirty=() locked_status=()
if ! get_all_worktrees_including_main worktree_paths branches commits status_dirty locked_status; then
  printf "No worktrees found.\n" >&2
  exit 1
fi

# Get current worktree path for comparison
current_worktree=$(get_current_worktree_path)

# Build and print worktree list
# WHY: Delegate filtering to library function (DRY — single source of truth).
# filter_worktrees() handles the Python subprocess call and no-match error.
printf "${BLUE}Worktrees:%s${NC}\n" ""
print_worktree_legend

# Use Python for filtering when branch filters or search terms are provided
if [[ -n "$branch_filters_str" || -n "$search_terms" ]]; then
  # Output arrays for filter_worktrees (nameref pattern).
  # IMPORTANT: Must NOT use names that collide with the function's internal
  # _wt_* locals — Bash namerefs resolve to the nearest scope first.
  declare -a filtered_paths=() filtered_branches=() filtered_commits=()
  declare -a filtered_dirty=() filtered_locked=()
  if ! filter_worktrees filtered_paths filtered_branches filtered_commits filtered_dirty filtered_locked "$branch_filters_str" "$search_terms"; then
    exit 1
  fi

  # Display filtered results
  for i in "${!filtered_paths[@]}"; do
    path="${filtered_paths[$i]}"
    branch="${filtered_branches[$i]}"
    commit="${filtered_commits[$i]}"
    dirty="${filtered_dirty[$i]}"
    locked="${filtered_locked[$i]}"

    # Build status indicators via centralized library function
    path_display="${path/#$HOME/\~}"
    is_current="false"
    [[ "$path" == "$current_worktree" ]] && is_current="true"
    is_detached="false"
    [[ -z "$branch" || "$branch" == "detached" ]] && is_detached="true"
    status_indicators="$(format_worktree_indicators "$is_current" "$dirty" "$locked" "$is_detached") "
    branch_display="${branch:-(detached)}"

    printf "%s%-20s %s %s\n" "$status_indicators" "$branch_display" "($commit)" "$path_display"
  done
else
  # No filtering: use original loop (Python already loaded all worktrees)
  match_count=0
  for i in "${!worktree_paths[@]}"; do
    path="${worktree_paths[$i]}"
    branch="${branches[$i]}"
    commit="${commits[$i]}"
    dirty="${status_dirty[$i]}"
    locked="${locked_status[$i]}"

    # Build status indicators via centralized library function
    path_display="${path/#$HOME/\~}"
    is_current="false"
    [[ "$path" == "$current_worktree" ]] && is_current="true"
    is_detached="false"
    [[ -z "$branch" || "$branch" == "detached" ]] && is_detached="true"
    status_indicators="$(format_worktree_indicators "$is_current" "$dirty" "$locked" "$is_detached") "
    branch_display="${branch:-(detached)}"

    printf "%s%-20s %s %s\n" "$status_indicators" "$branch_display" "($commit)" "$path_display"
    match_count=$((match_count + 1))
  done
fi
