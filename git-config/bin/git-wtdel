#!/usr/bin/env bash
_hug_category='["worktrees"]'; test "${1:-}" = '--search-meta' && { printf 'category = %s\n' "$_hug_category"; exit 0; }
# Assume HUG_HOME is set (exported by hug or environment)
# shellcheck source=git-config/lib/hug-common
. "$HUG_HOME/git-config/lib/hug-common"
# shellcheck source=git-config/lib/hug-git-kit
. "$HUG_HOME/git-config/lib/hug-git-kit"
# shellcheck source=git-config/lib/hug-git-worktree
. "$HUG_HOME/git-config/lib/hug-git-worktree"
set -euo pipefail # Exit on error, undefined vars, pipe failures
# Part of the Hug tool suite

show_help() {
  cat << 'EOF'
hug wtdel: Remove worktree(s) safely

USAGE:
    hug wtdel [branch...] [options]
    hug wtdel -p <path> [options]
    hug wtdel -h|--help

ARGUMENTS:
    [branch...]       One or more branch names (exact match, removes worktree for each)

OPTIONS:
    -p, --path PATH   Target worktree by filesystem path (repeatable for batch)
    -f, --force       Skip confirmation prompts and remove even with uncommitted changes
    -y, --yes         Skip confirmation prompts (keeps safe semantics)
    --dry-run         Show what would be removed without actually removing
    -B, --with-branch Also delete the associated branch after removing the worktree
    -h, --help        Show this help

DESCRIPTION:
    Removes Git worktree(s) safely. If no branch or path is provided, shows
    an interactive menu of all available worktrees for selection.

    Safety features:
    - Prevents removal of current worktree
    - Warns about uncommitted changes (unless --force is used)
    - Requires confirmation before deletion (unless --force is used)
    - Automatically cleans up Git worktree metadata
    - Automatically detects and prunes stale worktree metadata
      (directories removed externally without 'git worktree remove')
    - Supports batch removal of multiple worktrees

EXAMPLES:
    hug wtdel                                 # Interactive selection
    hug wtdel feature-auth                    # Remove worktree for branch "feature-auth"
    hug wtdel feat-1 feat-2 feat-3            # Batch remove by branch names
    hug wtdel feature-auth --dry-run          # Preview removal
    hug wtdel feature-auth -f                 # Force remove without confirmation
    hug wtdel -p /path/to/worktree            # Remove by path
    hug wtdel -p /path/a -p /path/b --force  # Batch remove by paths
    hug wtdel feature-auth -B              # Remove worktree and delete branch
    hug wtdel feat-1 feat-2 -B --force     # Batch remove worktrees + branches

SEE ALSO:
    hug wt      List and switch between worktrees
    hug wtc     Create worktree for existing branch
    hug wtl     List worktrees with optional branch filtering

FURTHER READING:
    See 'git worktree remove --help' for underlying implementation details.
EOF
}

show_interactive_removal_menu() {
  local selected_path=""
  # WHY: Capture rc with || because inside `if ! cmd; then`, $? is always 0.
  local select_rc=0
  select_worktree selected_path --exclude-current --prompt "Select worktree to remove" || select_rc=$?
  if [[ $select_rc -ne 0 ]]; then
    if [[ $select_rc -eq 2 ]]; then
      info "No removable worktrees found."
    else
      # rc=1: user cancelled (pressed Enter / gave empty input)
      info "Worktree removal cancelled"
    fi
    return 1
  fi
  printf '%s' "$selected_path"
  return 0
}

check_git_repo

# Parse arguments using getopt
set +e
PARSED=$(getopt --options hp:fBy --longoptions help,force,dry-run,path:,with-branch,yes --name "hug wtdel" -- "$@" 2>&1)
getopt_status=$?
set -e

if [ $getopt_status -ne 0 ]; then
  if [ -n "$PARSED" ]; then
    echo "$PARSED" >&2
  fi
  exit 1
fi

eval set -- "$PARSED"

# Initialize variables
force=false
dry_run=false
with_branch=false
declare -a branch_names=()
declare -a explicit_paths=()

# Process options
while true; do
  case "$1" in
  -h | --help)
    show_help
    exit 0
    ;;
  -f | --force)
    force=true
    shift
    ;;
  -y | --yes)
    export HUG_YES=true
    shift
    ;;
  --dry-run)
    dry_run=true
    shift
    ;;
  -B | --with-branch)
    with_branch=true
    shift
    ;;
  -p | --path)
    explicit_paths+=("$2")
    shift 2
    ;;
  --)
    shift
    break
    ;;
  *)
    error "Internal error in option parsing"
    ;;
  esac
done

# Check HUG_FORCE environment variable
if [[ ${HUG_FORCE:-} == true ]]; then
  force=true
fi

# Parse positional arguments as branch names
while [[ $# -gt 0 ]]; do
  branch_names+=("$1")
  shift
done

# Validate: can't mix branch names and explicit paths
if [[ ${#branch_names[@]} -gt 0 && ${#explicit_paths[@]} -gt 0 ]]; then
  error "Branch names and --path are mutually exclusive. Use one or the other."
  exit 1
fi

# Resolve branch names to worktree paths
declare -a worktree_paths=()
if [[ ${#branch_names[@]} -gt 0 ]]; then
  main_worktree=$(get_main_worktree_path)
  for bn in "${branch_names[@]}"; do
    worktree_path=$(get_worktree_path_by_branch "$bn" || true)
    if [[ -z "$worktree_path" ]]; then
      error "No worktree found for branch '$bn'"
      exit 1
    fi
    if [[ "$worktree_path" == "$main_worktree" ]]; then
      error "Cannot remove the main worktree (branch '$bn'). Use a different branch or specify -p for path."
      exit 1
    fi
    worktree_paths+=("$worktree_path")
  done
elif [[ ${#explicit_paths[@]} -gt 0 ]]; then
  worktree_paths=("${explicit_paths[@]}")
fi

# Convert relative paths to absolute
for i in "${!worktree_paths[@]}"; do
  if [[ ! "${worktree_paths[$i]}" = /* ]]; then
    worktree_paths[$i]="$(realpath "$(pwd)/${worktree_paths[$i]}" 2> /dev/null || echo "$(pwd)/${worktree_paths[$i]}")"
  fi
done

# If no paths provided (and no branch names), show interactive menu
if [[ ${#worktree_paths[@]} -eq 0 ]]; then
  worktree_path=$(show_interactive_removal_menu)
  if [[ -z "$worktree_path" ]]; then
    exit 0 # User cancelled
  fi
  worktree_paths=("$worktree_path")
fi

# Process each worktree path (batch support)
removed=()
failed=()
branches_deleted=()
branches_kept=()

# Delete the branch associated with a removed worktree.
# Args: $1=branch_name, $2=force (true/false), $3=dry_run (true/false)
# Returns: 0=deleted, 1=skipped/declined, 2=no branch to delete
delete_associated_branch() {
  local branch="$1"
  local _force="$2"
  local _dry_run="$3"

  # Skip detached HEAD or non-existent branches
  if [[ -z "$branch" || "$branch" == "HEAD" || "$branch" == "(detached)" || "$branch" == "unknown" ]]; then
    return 2
  fi

  # Check if branch still exists after worktree removal
  if ! git rev-parse --verify "refs/heads/$branch" > /dev/null 2>&1; then
    return 2
  fi

  # Determine merge status against default branch
  local default_branch
  default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2> /dev/null | sed 's@^refs/remotes/origin/@@' || git branch --list main master | head -1 | tr -d ' *')

  local is_merged=false
  if git branch --merged "${default_branch:-main}" 2> /dev/null | grep -q "^[ *]*${branch}$"; then
    is_merged=true
  fi

  # Dry run: just report what would happen
  if $_dry_run; then
    if $is_merged; then
      info "Would delete branch '$branch' (merged)"
    else
      info "Would delete branch '$branch' (has unmerged commits)"
    fi
    return 0
  fi

  # WHY: prompt_confirm_warn calls exit 1 on decline, NOT return 1.
  # Subshell contains the exit so we can track outcome in branches_kept.
  if $is_merged; then
    if ! $_force; then
      if ! (prompt_confirm_warn "Also delete branch '$branch'?"); then
        return 1
      fi
    fi
  else
    if ! $_force; then
      local unmerged_count
      unmerged_count=$(git rev-list --count "${default_branch:-main}..$branch" 2> /dev/null || echo "?")
      warning "Branch '$branch' has $unmerged_count unmerged commit(s)"
      if ! (prompt_confirm_warn "Delete unmerged branch '$branch' anyway?"); then
        return 1
      fi
    fi
  fi

  # Use -D for unmerged, -d for merged
  local delete_flag="-d"
  if ! $is_merged; then
    delete_flag="-D"
  fi

  if git branch "$delete_flag" "$branch" > /dev/null 2>&1; then
    success "Branch '$branch' deleted"
    return 0
  else
    # Force-delete as fallback (branch might not be fully merged even if we thought it was)
    if git branch -D "$branch" > /dev/null 2>&1; then
      success "Branch '$branch' deleted (force)"
      return 0
    fi
    warning "Failed to delete branch '$branch'"
    return 1
  fi
}

for worktree_path in "${worktree_paths[@]}"; do
  # Skip empty paths
  if [[ -z "$worktree_path" ]]; then
    warning "Skipping empty path"
    continue
  fi

  # --- PRE-VALIDATION ---
  # Validate worktree path (exists, is directory, is worktree)
  # WHY: Don't use validate_worktree_path() in batch mode because it calls error() which exits.
  # Instead, do inline checks that just return failure without exiting.
  path_valid=true
  if [[ ! -e "$worktree_path" ]]; then
    # WHY: Stale worktrees (directory deleted externally without git worktree remove)
    # leave orphaned metadata. Auto-pruning cleans this up instead of failing.
    if git worktree list --porcelain 2> /dev/null | grep -qxF "worktree $worktree_path"; then
      info "Worktree directory already removed: ${worktree_path/#$HOME/\~}"
      if ! $dry_run; then
        info "Cleaning up orphaned Git metadata..."
        # WHY: Locked stale worktrees won't be pruned by 'git worktree prune'
        # unless explicitly unlocked first. The lock file is metadata-only and
        # the directory is already gone, so unlocking is safe.
        git worktree unlock "$worktree_path" 2> /dev/null || true
        git worktree prune 2> /dev/null
        success "Pruned stale worktree entry: ${worktree_path/#$HOME/\~}"
      else
        info "Would prune stale worktree metadata (dry run)"
      fi
      removed+=("$worktree_path (pruned)")
      continue
    fi
    warning "Worktree path does not exist: $worktree_path"
    path_valid=false
  elif [[ ! -d "$worktree_path" ]]; then
    warning "Worktree path is not a directory: $worktree_path"
    path_valid=false
  elif ! worktree_exists "$worktree_path"; then
    warning "Path is not a Git worktree: $worktree_path"
    path_valid=false
  fi

  if ! $path_valid; then
    failed+=("$worktree_path")
    continue
  fi

  # Get branch name for display
  wt_branch=$(git -C "$worktree_path" rev-parse --abbrev-ref HEAD 2> /dev/null || echo "unknown")

  # Prevent removal of current worktree
  current_worktree=$(get_current_worktree_path)
  if [[ "$worktree_path" == "$current_worktree" ]]; then
    if [[ ${#worktree_paths[@]} -gt 1 ]]; then
      warning "Cannot remove the current worktree: $worktree_path"
    else
      error "Cannot remove current worktree: $worktree_path"
    fi
    failed+=("$worktree_path")
    continue
  fi

  # Check if worktree is locked
  if git worktree list --porcelain 2> /dev/null | grep -A1 "^worktree $worktree_path$" | grep -q "^locked"; then
    warning "Worktree is locked: $worktree_path. Unlock it first with: git worktree unlock '$worktree_path'"
    failed+=("$worktree_path")
    continue
  fi

  # --- DETECT DIRTY STATUS ---
  # WHY: Use library function instead of duplicating dirty detection logic.
  # This follows DRY principle and makes the check reusable across commands.
  is_dirty=false
  dirty_details=""
  get_worktree_dirty_details "$worktree_path" is_dirty dirty_details

  # Block dirty removal without --force (but allow dry-run to preview)
  if $is_dirty && ! $force && ! $dry_run; then
    echo >&2
    printf "${BLUE}Worktree Removal Summary:${NC}\n" >&2
    printf "  Branch: %s\n" "$wt_branch" >&2
    printf "  Path:   %s\n" "${worktree_path/#$HOME/\~}" >&2
    printf "  Status: ${YELLOW}Dirty (%s)${NC}\n" "$dirty_details" >&2
    echo >&2
    warning "Worktree has uncommitted changes: $worktree_path. Commit/stash first, or use -f/--force to discard."
    failed+=("$worktree_path")
    continue
  fi

  # Build status text
  if $is_dirty; then
    status_text="${RED}Dirty -- $dirty_details (will be permanently lost)${NC}"
  else
    status_text="${GREEN}Clean${NC}"
  fi

  # --- DRY RUN ---
  if $dry_run; then
    echo >&2
    if [[ ${#worktree_paths[@]} -gt 1 ]]; then
      printf "${BLUE}Worktree Removal Preview (DRY RUN) [$((${#failed[@]} + ${#removed[@]} + 1))/${#worktree_paths[@]}]:${NC}\n" >&2
    else
      printf "${BLUE}Worktree Removal Preview (DRY RUN):${NC}\n" >&2
    fi
    printf "  Branch: %s\n" "$wt_branch" >&2
    printf "  Path:   %s\n" "${worktree_path/#$HOME/\~}" >&2
    printf "  Status: %s\n" "$status_text" >&2
    if $with_branch; then
      printf "  Branch: %s (would be deleted)\n" "$wt_branch" >&2
    fi
    echo >&2
    if [[ ${#worktree_paths[@]} -eq 1 ]]; then
      info "No changes made (dry run)."
      exit 0
    fi
    removed+=("$worktree_path (dry run)")
    continue
  fi

  # --- SUMMARY ---
  echo >&2
  if [[ ${#worktree_paths[@]} -gt 1 ]]; then
    printf "${BLUE}Worktree Removal Summary [$((${#failed[@]} + ${#removed[@]} + 1))/${#worktree_paths[@]}]:${NC}\n" >&2
  else
    printf "${BLUE}Worktree Removal Summary:${NC}\n" >&2
  fi
  printf "  Branch: %s\n" "$wt_branch" >&2
  printf "  Path:   %s\n" "${worktree_path/#$HOME/\~}" >&2
  printf "  Status: %s\n" "$status_text" >&2
  echo >&2

  # --- SINGLE CONFIRMATION ---
  if ! $force; then
    if ! prompt_confirm_danger "remove"; then
      info "Worktree removal cancelled: $worktree_path"
      continue
    fi
  fi

  # --- EXECUTE ---
  git_wt_args=("$worktree_path")
  if $force; then
    git_wt_args+=("--force")
  fi

  git_err=""
  removal_success=false
  if ! git_err=$(git worktree remove "${git_wt_args[@]}" 2>&1); then
    # Fallback to manual cleanup
    warning "git worktree remove failed: $git_err"
    info "Attempting manual cleanup..."
    if rm -rf "$worktree_path" && git worktree prune 2> /dev/null; then
      success "Worktree removed for branch '$wt_branch' (manual cleanup)"
      info "Deleted directory: ${worktree_path/#$HOME/\~}"
      removal_success=true
    else
      error "Failed to remove worktree: $worktree_path. Manual intervention required."
    fi
  else
    # Verify removal
    if [[ -d "$worktree_path" ]]; then
      warning "Worktree directory still exists after removal. Running cleanup..."
      rm -rf "$worktree_path" 2> /dev/null || true
      git worktree prune 2> /dev/null || true
    fi
    removal_success=true
  fi

  # Run prune to clean up metadata
  git worktree prune 2> /dev/null || true

  # Track result
  if $removal_success; then
    success "Worktree removed for branch '$wt_branch'"
    info "Deleted directory: ${worktree_path/#$HOME/\~}"

    # Branch deletion (if --with-branch is active)
    if $with_branch; then
      branch_rc=0
      delete_associated_branch "$wt_branch" "$force" "$dry_run" || branch_rc=$?
      if [[ $branch_rc -eq 0 ]]; then
        branches_deleted+=("$wt_branch")
      elif [[ $branch_rc -eq 1 ]]; then
        branches_kept+=("$wt_branch")
      fi
      # rc=2 means skipped (detached/non-existent) — no tracking needed
    else
      tip "Branch '$wt_branch' still exists. To delete it: hug bdel $wt_branch"
    fi

    echo >&2
    removed+=("$worktree_path")
  else
    failed+=("$worktree_path")
  fi
done

# --- BATCH SUMMARY ---
if [[ ${#worktree_paths[@]} -gt 1 ]]; then
  echo >&2
  printf "${BLUE}Batch Removal Summary:${NC}\n" >&2
  printf "  Removed: ${#removed[@]}\n" >&2
  if [[ ${#failed[@]} -gt 0 ]]; then
    printf "  Failed: ${#failed[@]}\n" >&2
  fi
  if $with_branch; then
    if [[ ${#branches_deleted[@]} -gt 0 ]]; then
      printf "  Branches deleted: ${#branches_deleted[@]}\n" >&2
    fi
    if [[ ${#branches_kept[@]} -gt 0 ]]; then
      printf "  Branches kept: ${#branches_kept[@]}\n" >&2
    fi
  fi
  echo >&2

  if [[ ${#failed[@]} -gt 0 ]]; then
    exit 1
  fi
elif [[ ${#failed[@]} -gt 0 ]]; then
  # Single path but failed
  exit 1
fi
