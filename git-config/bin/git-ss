#!/usr/bin/env bash
CMD_BASE="$(readlink -f "$0" 2> /dev/null || greadlink -f "$0")" || CMD_BASE="$0"
CMD_BASE="$(dirname "$CMD_BASE")"
for f in hug-common hug-git-kit; do . "$CMD_BASE/../lib/$f"; done
set -euo pipefail

# Part of the Hug tool suite

show_help() {
  cat << 'EOF'
hug ss: Show status with patch of staged diff.

USAGE:
    hug ss [-s, --stat] [-q, --quiet] [-h, --help]
    hug ss [--] [<path>...]
    hug ss --
    hug ss --browse-root

ARGUMENTS:
    <path>...      Show staged diff for specific paths (optional, supports multiple)
    --             With no paths: interactive file selection from staged files
                   With paths: separates flags from pathspecs

OPTIONS:
    --browse-root  Browse full repository scope in file selector UI (default: current directory)
    -s, --stat     Show only file statistics (omit patch)
    -q, --quiet    Suppress summary line (also honors HUG_QUIET env var)
    -h, --help     Show this help

DESCRIPTION:
    Shows the staged diff (what will be committed). When no file
    is specified, shows all staged diff. By default shows both patch and
    statistics. Use '--stat' to show statistics only, or '--no-stats' to
    show patch only. Use '--' alone to interactively select a file from staged files.

PATH FILTERING:
    Append -- <path>... to restrict output to matching paths.
    Globs must be quoted to prevent shell expansion.

    hug ss -- src/ tests/          # Show staged diff for two directories
    hug ss --stat -- '*.java'      # Stats for Java files only

EXAMPLES:
    hug ss                  # Show all staged diff (patch + stats)
    hug ss --stat           # Show only staged statistics
    hug ss file.txt         # Show staged diff for specific file
    hug ss --stat file.txt  # Show stats for specific file only
    hug ss -- src/ tests/   # Show staged diff for two directories
    hug ss --               # Interactive file selection (current directory)
    hug ss --browse-root    # Interactive file selection (full repository)

SEE ALSO:
    hug su       : Show unstaged diff
    hug sw       : Show working directory changes
    hug s        : Show status
EOF
}

# Delegate all argument processing and diff invocation to the shared driver
_diff_cmd_setup "staged" "--staged" "Select file(s) to view staged diff..." "$@"
